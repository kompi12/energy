<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/app.log</file>
        <append>true</append>
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss}] [%-5level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Only log your application's package -->
    <logger name="com.example.energy" level="INFO" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Root logger set to ERROR to suppress Spring/Hibernate INFO -->
    <root level="ERROR">
        <appender-ref ref="FILE"/>
    </root>
</configuration>
